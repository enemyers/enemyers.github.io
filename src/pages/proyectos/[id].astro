---
import Scroller from '../../components/Scroller.jsx';
import projects from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project.title} | Detalle</title>
  </head>
  <body class="bg-gradient-to-br from-zinc-950 to-slate-900 min-h-screen text-white">
    <main class="max-w-5xl mx-auto px-4 py-16">
      <a href="/proyectos" class="text-cyan-300 underline hover:text-cyan-200">
        ← Volver a proyectos
      </a>

      <section class="mt-8 rounded-2xl border border-slate-700 bg-slate-800/70 p-8 shadow-xl">
        <p class="text-cyan-300 uppercase tracking-[0.2em] text-xs mb-3">Caso de estudio</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight">{project.title}</h1>
        <p class="mt-4 text-cyan-100 text-lg max-w-3xl">
          {project.description}. Esta vista es una plantilla propuesta para presentar contexto,
          objetivos, arquitectura y resultados del proyecto.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {project.tech.map((tech) => (
            <span class="px-3 py-1 rounded-full text-sm bg-cyan-500/90 text-white">{tech}</span>
          ))}
        </div>
      </section>

      <section class="grid md:grid-cols-3 gap-6 mt-10">
        <article class="rounded-xl border border-slate-700 bg-slate-800 p-6">
          <h2 class="text-xl font-semibold mb-3">Problema</h2>
          <p class="text-slate-300">
            Describe aquí la necesidad del cliente o usuario y los retos principales del proyecto.
          </p>
        </article>
        <article class="rounded-xl border border-slate-700 bg-slate-800 p-6">
          <h2 class="text-xl font-semibold mb-3">Solución</h2>
          <p class="text-slate-300">
            Explica el enfoque funcional y técnico aplicado, con énfasis en decisiones de arquitectura.
          </p>
        </article>
        <article class="rounded-xl border border-slate-700 bg-slate-800 p-6">
          <h2 class="text-xl font-semibold mb-3">Impacto</h2>
          <p class="text-slate-300">
            Incluye métricas o mejoras medibles: rendimiento, conversión, mantenimiento o escalabilidad.
          </p>
        </article>
      </section>

      <section class="mt-10 rounded-xl border border-slate-700 bg-slate-800 p-6">
        <header class="text-center">
          <h2 class="text-2xl font-semibold">Estructura sugerida de la plantilla</h2>
          <p class="mt-2 text-slate-300 max-w-2xl mx-auto">
            Una guía breve para presentar cualquier proyecto de forma profesional.
          </p>
        </header>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <article class="rounded-lg border border-slate-600 bg-slate-900/60 p-4">
            <p class="text-cyan-300 font-semibold">01. Contexto</p>
            <p class="mt-1 text-slate-200">Resumen ejecutivo del proyecto en 2 o 3 líneas.</p>
          </article>

          <article class="rounded-lg border border-slate-600 bg-slate-900/60 p-4">
            <p class="text-cyan-300 font-semibold">02. Objetivos</p>
            <p class="mt-1 text-slate-200">Objetivos de negocio y requerimientos técnicos.</p>
          </article>

          <article class="rounded-lg border border-slate-600 bg-slate-900/60 p-4">
            <p class="text-cyan-300 font-semibold">03. Diseño técnico</p>
            <p class="mt-1 text-slate-200">Arquitectura de alto nivel y stack utilizado.</p>
          </article>

          <article class="rounded-lg border border-slate-600 bg-slate-900/60 p-4">
            <p class="text-cyan-300 font-semibold">04. Evidencia visual</p>
            <p class="mt-1 text-slate-200">Capturas, demo o flujo principal de usuario.</p>
          </article>

          <article class="rounded-lg border border-slate-600 bg-slate-900/60 p-4 md:col-span-2">
            <p class="text-cyan-300 font-semibold">05. Resultados</p>
            <p class="mt-1 text-slate-200">Resultados, aprendizajes y próximos pasos.</p>
          </article>
        </div>
      </section>

      <section class="mt-10 flex flex-wrap justify-end gap-4">
        <a
          href="/contacto"
          class="inline-block px-6 py-3 bg-cyan-700 rounded-lg shadow hover:bg-cyan-600 transition text-white font-semibold"
        >
          Contactar
        </a>
      </section>
    </main>

    <Scroller client:load />
  </body>
</html>
---
import AnimatedText from "../components/AnimatedText.jsx";
import ProjectCard from "../components/ProjectCard.jsx";
import personalData from "../data/personalData";
import avatar from "../assets/avatar.jpg";
import projects from "../data/projects";
import Scroller from "../components/Scroller.jsx";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | Inicio</title>
  </head>
  <body
    class="bg-gradient-to-br from-slate-900 to-indigo-900 min-h-screen text-white"
  >
    <main class="max-w-3xl mx-auto py-20 px-4">
      <style>
        .avatar-animated-border {
          background: conic-gradient(
            from 0deg,
            #6366f1,
            #a21caf,
            #ec4899,
            #6366f1 360deg
          );
          animation: spin 4s linear infinite;
        }
        @keyframes spin {
          100% {
            transform: rotate(360deg);
          }
        }
      </style>
      <div class="flex justify-center mb-6">
        <div class="relative" style="width: 138px; height: 138px;">
          <div
            class="absolute inset-0 rounded-full p-1 avatar-animated-border shadow-lg"
          >
          </div>
          <img
            src={avatar.src}
            alt="Avatar de Nicolas Herrera"
            width={128}
            height={128}
            loading="eager"
            class="w-32 h-32 rounded-full object-cover border-4 border-slate-900 absolute left-1/2 top-1/2"
            style="transform: translate(-50%, -50%);"
          />
        </div>
      </div>
      <div class="text-center">
        <AnimatedText
          text={`¡Hola! Soy ${personalData.nombre}`}
          className="text-5xl mb-6"
          client:load
        />
        <p class="text-xl mb-8">{personalData.bio}</p>
        <div class="flex justify-center gap-6 mb-8">
          <a
            href={personalData.redes.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="hover:scale-110 transition"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-indigo-400"
              ><path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.804-1.75-1.732s.784-1.732 1.75-1.732 1.75.804 1.75 1.732-.784 1.732-1.75 1.732zm13.5 11.268h-3v-5.604c0-1.337-.025-3.063-1.868-3.063-1.868 0-2.154 1.459-2.154 2.968v5.699h-3v-10h2.881v1.367h.041c.401-.761 1.379-1.563 2.838-1.563 3.036 0 3.599 2 3.599 4.591v5.605z"
              ></path></svg
            >
          </a>
          <a
            href={personalData.redes.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="hover:scale-110 transition"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-indigo-400"
              ><path
                d="M12 0c-6.627 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.6.113.793-.258.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.809 1.304 3.495.997.108-.775.418-1.304.762-1.604-2.665-.305-5.466-1.334-5.466-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.553 3.297-1.23 3.297-1.23.653 1.653.242 2.873.119 3.176.77.84 1.235 1.91 1.235 3.221 0 4.609-2.803 5.624-5.475 5.921.43.372.823 1.102.823 2.222v3.293c0 .322.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
          </a>
          <a
            href={`mailto:${personalData.email}`}
            aria-label="Email"
            class="hover:scale-110 transition"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-indigo-400"
              ><path
                d="M12 13.065l-11.714-7.065h23.428l-11.714 7.065zm11.714-8.065h-23.428c-.711 0-1.286.575-1.286 1.286v15.428c0 .711.575 1.286 1.286 1.286h23.428c.711 0 1.286-.575 1.286-1.286v-15.428c0-.711-.575-1.286-1.286-1.286zm-11.714 10.935l-11.714-7.065v13.065h23.428v-13.065l-11.714 7.065z"
              ></path></svg
            >
          </a>
        </div>
      </div>
      <div class="flex gap-4 mt-8 justify-center flex-wrap">
  <a
    href="/sobre-mi"
    class="inline-block px-6 py-3 bg-indigo-600 rounded-lg shadow hover:bg-indigo-500 transition"
  >
    Conoce más sobre mí
  </a>
  <a
    href="/skills"
    class="inline-block px-6 py-3 bg-slate-700 rounded-lg shadow hover:bg-slate-600 transition text-white font-semibold"
  >
    Skills
  </a>
  <a
    href="/contacto"
    class="inline-block px-6 py-3 bg-pink-600 rounded-lg shadow hover:bg-pink-500 transition text-white font-semibold"
  >
    Contacto
  </a>
</div>

      <section class="mt-12">
        <AnimatedText
          text="Proyectos Destacados"
          className="text-3xl mb-12 text-center"
          client:load
        />
        <div class="grid gap-6 md:grid-cols-2">
          {
            projects
              .filter((p) => p.id === "proyecto-1" || p.id === "proyecto-3")
              .map((project) => <ProjectCard client:load {...project} />)
          }
        </div>
        <div class="mt-8 text-center">
          <a
            href="/proyectos"
            class="inline-block px-6 py-3 bg-indigo-600 rounded-lg shadow hover:bg-indigo-500 transition text-white font-semibold"
          >
            Ver todos los proyectos
          </a>
        </div>
      </section>
    </main>
    <Scroller client:load />
  </body>
</html>

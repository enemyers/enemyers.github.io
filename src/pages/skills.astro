---
import AnimatedText from "../components/AnimatedText.jsx";
import SkillsProgress from "../components/SkillsProgress.jsx";
import skillsByCategory from "../data/skills";
import Scroller from "../components/Scroller.jsx";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Skills | Nicolas Herrera</title>
  </head>
  <body class="bg-slate-950 text-white min-h-screen">
    <main class="max-w-3xl mx-auto px-4 py-12">
      <AnimatedText text="Skills" className="text-5xl mb-8" client:load />
      {skillsByCategory.map(cat => (
        <div class="mb-8">
          <h3 class="text-xl font-semibold mb-4">{cat.category}</h3>
          <SkillsProgress skills={cat.skills} client:load />
        </div>
      ))}
      <div class="flex gap-4 mt-12 justify-center">
        <a href="/" class="inline-block px-6 py-3 bg-slate-700 rounded-lg shadow hover:bg-slate-600 transition text-white font-semibold">Inicio</a>
        <a href="/proyectos" class="inline-block px-6 py-3 bg-indigo-600 rounded-lg shadow hover:bg-indigo-500 transition text-white font-semibold">Proyectos</a>
      </div>
    </main>
    <Scroller client:load />
  </body>
</html>

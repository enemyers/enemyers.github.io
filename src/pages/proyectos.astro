---
import ProjectCard from '../components/ProjectCard.jsx';
import proyectos from '../data/projects';
import skillsByCategory from '../data/skills';

const skillLevelByName = new Map(
  skillsByCategory.flatMap((category) =>
    category.skills.map((skill) => [skill.name.toLowerCase(), skill.level] as const),
  ),
);

const skillAliases: Record<string, string> = {
  tailwind: 'tailwind css',
  'node.js': 'javascript',
};

const getSkillLevel = (tech: string) => {
  const normalized = tech.toLowerCase();
  const alias = skillAliases[normalized] ?? normalized;
  return skillLevelByName.get(alias) ?? 0;
};

const proyectosOrdenados = [...proyectos].sort((a, b) => {
  const scoreA = a.tech.reduce((sum, tech) => sum + getSkillLevel(tech), 0);
  const scoreB = b.tech.reduce((sum, tech) => sum + getSkillLevel(tech), 0);
  return scoreB - scoreA;
});
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | Proyectos</title>
  </head>
  <body class="bg-gradient-to-br from-zinc-950 to-slate-900 min-h-screen text-white">
    <main class="max-w-4xl mx-auto py-20 px-4">
      <h1 class="text-4xl font-bold mb-12">Proyectos</h1>
      <p class="text-xl mb-12">Aquí puedes ver algunos de mis proyectos más destacados.</p>

      <div class="grid gap-8 md:grid-cols-2">
        {proyectosOrdenados.map((proyecto) => (
          <ProjectCard client:load {...proyecto} />
        ))}
      </div>

      <div class="mt-12">
        <a href="/" class="text-cyan-300 underline hover:text-cyan-200">← Volver al inicio</a>
      </div>
    </main>
  </body>
</html>

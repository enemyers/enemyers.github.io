---
import { motion } from 'framer-motion';

interface Props {
  title: string;
  description: string;
  tech: string[];
  link?: string;
}

const { title, description, tech, link } = Astro.props;
---

<motion.div
  className="bg-slate-800 rounded-lg p-6 shadow-lg transition-transform transition-shadow duration-300 cursor-pointer"
  initial={{ opacity: 0, scale: 0.95 }}
  whileInView={{ opacity: 1, scale: 1 }}
  whileHover={{ scale: 1.04, boxShadow: '0 8px 32px 0 rgba(34,211,238,0.35)' }}
  viewport={{ once: true }}
  transition={{ duration: 0.3, type: 'spring', stiffness: 300 }}
>
  <h3 class="text-xl font-semibold mb-2">{title}</h3>
  <p class="text-cyan-100 mb-4">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tech.map((tech) => (
      <span class="px-2 py-1 bg-cyan-500 rounded text-sm">{tech}</span>
    ))}
  </div>
  {link && (
    <a
      href={link}
      class="inline-block text-cyan-300 hover:text-cyan-200 underline"
      target="_blank"
      rel="noopener noreferrer"
    >
      Ver proyecto
    </a>
  )}
</motion.div>

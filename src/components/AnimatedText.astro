---
import { motion } from 'framer-motion';

interface Props {
  text: string;
  className?: string;
}

const { text, className = '' } = Astro.props;
---

<motion.div
  className={`font-bold text-4xl ${className}`}
  initial={{ opacity: 0, y: 20 }}
  whileInView={{ opacity: 1, y: 0 }}
  transition={{ duration: 0.8 }}
  viewport={{ once: true }}
>
  {text}
</motion.div>
